{
  "version": 2,
  "routes": [
    {
      "src": "/playlist",
      "dest": "/api/playlist.py"
    },
    {
      "src": "/reorder",
      "dest": "/api/reorder.py"
    },
    {
      "src": "/playlist/(.*)",
      "dest": "/api/serve_file.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
